package form

import lw "github.com/Design-Machines-Studio/livewires-templ"

// SelectOption represents an option in a select dropdown.
type SelectOption struct {
	Value    string // Option value
	Label    string // Display label
	Selected bool   // Whether this option is selected
}

// SelectProps holds configuration for a select dropdown component.
type SelectProps struct {
	Label       string           // Field label
	Name        string           // Field name (also used as ID)
	Placeholder string           // Placeholder text for empty option
	Options     []SelectOption   // Available options
	Required    bool             // Whether field is required
	Hint        string           // Helper text below the field
	Class       string           // Additional CSS classes on the wrapper
	Attrs       templ.Attributes // Catch-all for the select: data-*, aria-*, etc.
}

// Select renders a complete select dropdown with label and optional hint.
templ Select(data SelectProps) {
	<div class={ lw.ClassNames("stack stack-compact", data.Class) }>
		<label for={ data.Name } class="font-semibold">{ data.Label }</label>
		<select
			id={ data.Name }
			name={ data.Name }
			required?={ data.Required }
			{ data.Attrs... }
		>
			if data.Placeholder != "" {
				<option value="">{ data.Placeholder }</option>
			}
			for _, opt := range data.Options {
				<option value={ opt.Value } selected?={ opt.Selected }>{ opt.Label }</option>
			}
		</select>
		if data.Hint != "" {
			<p class="text-xs text-muted">{ data.Hint }</p>
		}
	</div>
}

// SelectSimple is a convenience wrapper for basic selects.
templ SelectSimple(label, name, placeholder string, options []SelectOption, required bool) {
	@Select(SelectProps{
		Label:       label,
		Name:        name,
		Placeholder: placeholder,
		Options:     options,
		Required:    required,
	})
}
